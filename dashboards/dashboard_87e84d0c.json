      "id": "component_1",
      "title": "Most Expensive Products",
      "type": "table",
      "description": "List of products sorted by unit price",
      "sql": "SELECT \"ProductName\", \"UnitPrice\" FROM \"Products\" ORDER BY \"UnitPrice\" DESC"
    },
    {
      "id": "component_2",
      "title": "Product Categories Distribution",
      "type": "pie_chart",
      "description": "Distribution of products across different categories",
      "sql": "SELECT c.\"CategoryName\", COUNT(p.\"ProductID\") AS \"ProductCount\" FROM \"Products\" p JOIN \"Categories\" c ON p.\"CategoryID\" = c.\"CategoryID\" GROUP BY c.\"CategoryName\""
    },
    {
      "id": "component_3",
      "title": "Total Inventory Value",
      "type": "kpi",
      "description": "Total value of all products in stock",
      "sql": "SELECT SUM(\"UnitPrice\" * \"UnitsInStock\") AS \"TotalInventoryValue\" FROM \"Products\""
    }
